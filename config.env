# EU Custom Data Hub — user-editable install/run configuration.
#
# Values below are read by install.sh / install.ps1 / run.sh / run.ps1.
# Edit this file BEFORE running install.sh if you need to change any port
# or model. Re-running install.sh propagates changes into the generated
# .env files (customsandtaxriskmanagemensystem/.env, vat_fraud_detection/.env).
#
# Lines are `KEY=VALUE`. No spaces around `=`. No quotes needed.

# Port the FastAPI backend listens on.
BACKEND_PORT=8505

# Port the C&T operator dashboard (customsandtaxriskmanagemensystem) uses
# in dev mode (`npm run dev`).
CT_FRONTEND_PORT=8080


# ── LLM provider selection ────────────────────────────────────────────
# The VAT Fraud Detection agent supports four providers. Pick ONE.
#
#   lmstudio   — local LM Studio server. No API key. Best privacy,
#                needs ≥ 16 GB RAM. Default.
#   openai     — OpenAI cloud (api.openai.com). Set LLM_API_KEY.
#   anthropic  — Anthropic Claude. Set LLM_API_KEY.
#   azure      — Azure-hosted OpenAI. Set LLM_API_KEY + AZURE_OPENAI_*.
LLM_PROVIDER=lmstudio

# Default model identifier. Provider-specific format:
#   lmstudio   → as registered in LM Studio
#                (e.g. mistralai/mistral-7b-instruct-v0.3)
#   openai     → e.g. gpt-4o-mini, gpt-4o, gpt-4-turbo
#   anthropic  → e.g. claude-sonnet-4-6, claude-opus-4-7
#   azure      → ignored (uses AZURE_OPENAI_DEPLOYMENT below)
LLM_MODEL=mistralai/mistral-7b-instruct-v0.3

# API key for cloud providers. LM Studio ignores this. Leave blank for
# lmstudio. The key lands in vat_fraud_detection/.env (git-ignored) —
# it never enters source control. You can also set provider-specific
# env vars (OPENAI_API_KEY / ANTHROPIC_API_KEY / AZURE_OPENAI_API_KEY)
# in your shell instead of pasting it here.
LLM_API_KEY=

# Optional endpoint override. Useful for OpenAI-compatible proxies
# (Together, Groq, Mistral cloud) or a non-default LM Studio port.
# Leave blank to use the provider's default.
LLM_BASE_URL=


# ── LM Studio specifics (only read when LLM_PROVIDER=lmstudio) ────────
# Base URL of the local LM Studio server (no trailing slash, no /v1).
# LM Studio's default Developer-tab port is 1234.
LM_STUDIO_URL=http://localhost:1234

# Legacy alias for LLM_MODEL when LLM_PROVIDER=lmstudio. Kept for
# back-compat with older docs; new installs should use LLM_MODEL above.
LM_STUDIO_MODEL=mistralai/mistral-7b-instruct-v0.3


# ── Azure OpenAI specifics (only read when LLM_PROVIDER=azure) ────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
